{
    "name": "create-nest-next-template",
    "version": "0.1.0",
    "description": "Scaffold a NestJS + Next.js + Clerk + Prisma Turborepo monorepo",
    "license": "MIT",
    "type": "module",
    "bin": {
        "create-nest-next-template": "./dist/index.js"
    },
    "files": [
