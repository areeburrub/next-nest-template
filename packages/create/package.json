        "directory": "packages/create"
    },
    "dependencies": {
        "@clack/prompts": "^0.10.1",
        "execa": "^9.5.2",
        "giget": "^2.0.0",
        "picocolors": "^1.1.1"
    },
    "devDependencies": {
        "@types/node": "^22.10.0",
        "typescript": "^5.7.3"
    },
    "engines": {
        "node": ">=20.19"
    }
