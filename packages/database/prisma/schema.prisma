generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model UserEntity {
    id        String   @id
    email     String   @unique
    firstName String?
    lastName  String?
    imageUrl  String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("users")
}
