{
    "name": "nest-next-template",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "check-types": "turbo run check-types",
        "build:backend": "turbo run build --filter=@nest-next-template/backend",
        "start:backend": "turbo run start --filter=@nest-next-template/database --filter=@nest-next-template/backend",
        "db:migrate": "cd packages/database && bun run db:migrate",
        "db:migrate:deploy": "cd packages/database && bun run db:migrate:deploy",
        "db:studio": "cd packages/database && bun run dev",
        "create": "cd packages/create && bun run build && node dist/index.js"
    },
    "devDependencies": {
        "prettier": "^3.7.4",
        "turbo": "^2.9.14",
        "typescript": "5.9.2"
    },
    "packageManager": "bun@1.3.8",
    "engines": {
        "node": ">=20.19"
    }
}
