{
    "name": "next-nest-template",
    "description": "Next.js + NestJS + Clerk + Prisma Turborepo monorepo boilerplate",
    "license": "MIT",
    "private": true,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/areeburrub/next-nest-template.git"
    },
    "bugs": {
        "url": "https://github.com/areeburrub/next-nest-template/issues"
    },
    "homepage": "https://github.com/areeburrub/next-nest-template#readme",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "check-types": "turbo run check-types",
        "build:backend": "turbo run build --filter=@next-nest-template/backend",
        "start:backend": "turbo run start --filter=@next-nest-template/database --filter=@next-nest-template/backend",
        "db:migrate": "cd packages/database && bun run db:migrate",
        "db:migrate:deploy": "cd packages/database && bun run db:migrate:deploy",
        "db:studio": "cd packages/database && bun run dev",
        "create": "cd packages/create && bun run build && node dist/index.js"
    },
    "devDependencies": {
        "prettier": "^3.7.4",
        "turbo": "^2.9.14",
        "typescript": "5.9.2"
    },
    "packageManager": "bun@1.3.8",
    "engines": {
        "node": ">=20.19"
    }
}
